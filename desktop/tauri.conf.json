{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kivo",
  "version": "0.4.1",
  "identifier": "com.kivo.desktop",
  "build": {
    "beforeDevCommand": "pnpm frontend:dev",
    "beforeBuildCommand": "pnpm frontend:build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kivo",
        "width": 1180,
        "height": 720,
        "resizable": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https: http: wss: ws:; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'none'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/TrisH0x2A/Kivo/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI1ODhGOEUyQTIyNzg1MjcKUldRbmhTZWk0dmlJdFNUY21qaGRtUmhuUmFXZ0ZHUTY5UnpqVFlGN2xQL2czS1hXRXEreXQ3MEYK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "msi",
      "nsis",
      "deb",
      "rpm",
      "dmg",
      "app"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "languages": [
          "English"
        ]
      },
      "wix": {
        "language": [
          "en-US"
        ]
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    }
  }
}
